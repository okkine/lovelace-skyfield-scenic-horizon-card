{
  "name": "skyfield-scenic-horizon-card",
  "version": "1.0.0",
  "description": "A Home Assistant Lovelace card that displays a scenic day/night landscape driven by Skyfield sensors",
  "main": "dist/skyfield-scenic-horizon-card.js",
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "skyfield",
    "sun",
    "moon"
  ],
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^12.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "custom-card-helpers": "^1.9.0",
    "eslint": "^9.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "lit": "^3.0.0"
  }
}
